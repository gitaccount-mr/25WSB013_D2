#include <SPI.h>
#include <nRF24L01.h>
#include <RF24.h>
#include <TM1637Display.h>

// ── Pin definitions ──────────────────────────────────────
#define CLK       2
#define DIO       3
#define JOY_X     A0
#define JOY_Y     A1
#define JOY_BTN   4
#define CD_SWITCH 6

// ── Tuning constants ─────────────────────────────────────
#define DEADZONE   100
#define CENTRE     512
#define SMOOTH_N   5
#define CHANGE_MIN 2
#define SEND_MS    75
#define PAYLOAD_SIZE 20

// ── Objects ───────────────────────────────────────────────
RF24 radio(8, 7);
const byte addresses[][6] = {"00001", "00002"};
TM1637Display display(CLK, DIO);

// ── State ─────────────────────────────────────────────────
int lastServo1 = 93, lastServo2 = 93, lastCD = 0;
int lastReceivedNumber = 0;
unsigned long lastSendTime = 0;

bool cdToggle = false;
bool lastBtnState = HIGH;

// ── Helpers ───────────────────────────────────────────────
int readSmoothed(int pin) {
  long sum = 0;
  for (int i = 0; i < SMOOTH_N; i++) sum += analogRead(pin);
  return sum / SMOOTH_N;
}

bool isCentred(int raw) {
  return abs(raw - CENTRE) < DEADZONE;
}

// ─────────────────────────────────────────────────────────
void setup() {
  Serial.begin(9600);
  pinMode(JOY_BTN, INPUT_PULLUP);
  pinMode(CD_SWITCH, INPUT_PULLUP);

  display.setBrightness(0x0f);
  display.showNumberDec(0);

  radio.begin();
  radio.setChannel(100);
  radio.setPayloadSize(PAYLOAD_SIZE);
  radio.setPALevel(RF24_PA_LOW);
  radio.openWritingPipe(addresses[0]);
  radio.openReadingPipe(1, addresses[1]);
  radio.startListening();
}

// ─────────────────────────────────────────────────────────
void loop() {
  unsigned long now = millis();

  // ── Button: toggle CD_MODE on press ───────────────────
  bool btnState = digitalRead(JOY_BTN);
  if (btnState == LOW && lastBtnState == HIGH) {
    cdToggle = !cdToggle;
  }
  lastBtnState = btnState;

  // ── Read inputs ────────────────────────────────────────
  int rawX = readSmoothed(JOY_X);
  int rawY = readSmoothed(JOY_Y);

  bool switchOn = (digitalRead(CD_SWITCH) == HIGH);
  int CD_MODE = (switchOn ^ cdToggle) ? 1 : 0;

  // ── Calculate servo values ─────────────────────────────
  int servo1, servo2;

  if (isCentred(rawX) && isCentred(rawY)) {
    servo1 = 93;
    servo2 = 93;
  } else {
    int base = map(rawY, 0, 1023, 0, 180);
    int turn = map(rawX, 0, 1023, -90, 90);
    servo1 = constrain(base + turn, 0, 180);
    servo2 = constrain(180 - (base - turn), 0, 180);
  }

  // ── Suppress noise ────────────────────────────────────
  if (abs(servo1 - lastServo1) <= 1) servo1 = lastServo1;
  if (abs(servo2 - lastServo2) <= 1) servo2 = lastServo2;

  // ── Transmit only on meaningful change + interval ──────
  bool changed = (abs(servo1 - lastServo1) >= CHANGE_MIN)
              || (abs(servo2 - lastServo2) >= CHANGE_MIN)
              || (CD_MODE != lastCD);

  if (changed && (now - lastSendTime >= SEND_MS)) {
    char buf[PAYLOAD_SIZE] = {0};
    sprintf(buf, "%d,%d,%d", servo1, servo2, CD_MODE);

    radio.stopListening();
    radio.write(buf, PAYLOAD_SIZE);
    radio.startListening();

    Serial.print("Sending: "); Serial.println(buf);

    lastServo1 = servo1;
    lastServo2 = servo2;
    lastCD = CD_MODE;
    lastSendTime = now;
  }

  // ── Receive feedback ───────────────────────────────────
  if (radio.available()) {
    radio.read(&lastReceivedNumber, sizeof(lastReceivedNumber));
    Serial.print("Received: "); Serial.println(lastReceivedNumber);
  }

  display.showNumberDec(lastReceivedNumber, true);
}
